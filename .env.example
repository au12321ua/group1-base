# ==========================================
# STSS-g1 环境变量（示例）
# 复制此文件为 .env 并填入真实值
# ==========================================

# === 运行环境 ===
ENV=development

# === Auth Service 数据库（SQLite） ===
AUTH_DATABASE_URL=sqlite+aiosqlite:///./data/auth.db

# === Info Service 数据库（SQLite） ===
INFO_DATABASE_URL=sqlite+aiosqlite:///./data/info.db

# === 审计数据库（SQLite） ===
AUDIT_DATABASE_URL=sqlite+aiosqlite:///./data/audit.db

# === JWT 配置 ===
TOKEN_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
TOKEN_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# === 登录保护 ===
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# === 跨服务通信（Info Service 调用 Auth Service） ===
AUTH_SERVICE_URL=http://auth_service:8001

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=pdf,doc,docx,xls,xlsx,jpg,png
