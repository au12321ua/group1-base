# ==========================================
# STSS-g1 环境变量模板
# 复制此文件为 .env 后即可本地运行
# cp .env.example .env
# ==========================================

# === 运行环境 ===
ENV=development

# === 日志 ===
LOG_LEVEL=DEBUG
LOG_OUTPUT=console
LOG_DIR=./logs
LOG_ROTATION=daily
LOG_RETENTION=30

# === Auth Service 数据库（SQLite） ===
AUTH_DATABASE_URL=sqlite+aiosqlite:///./data/auth.db

# === Info Service 数据库（SQLite） ===
INFO_DATABASE_URL=sqlite+aiosqlite:///./data/info.db

# === 审计数据库（SQLite）===
AUDIT_DATABASE_URL=sqlite+aiosqlite:///./data/audit.db

# === JWT 配置 ===
JWT_SUPPORT_HS256=true
JWT_SUPPORT_RS256=false
JWT_SIGNING_ALGORITHM=HS256
TOKEN_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_HS256_KEY_ID=auth-hs256-key-1
# RS256（JWT_SUPPORT_RS256=true 时必填）
# JWT_RSA_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWT_RSA_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# JWT_RSA_KEY_ID=auth-rs256-key-1
ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=7
SERVICE_TOKEN_EXPIRE_HOURS=8

# === 密码加密 ===
BCRYPT_COST_FACTOR=12

# === 登录保护 ===
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=10

# === 内部用户默认密码（Info 创建用户时 Auth 侧初始凭据）===
DEFAULT_INITIAL_PASSWORD=ChangeMe123

# === 跨服务客户端凭据（/auth/sys/login）===
# Info Service — 调用 Auth /internal/* 端点
SERVICE_CLIENT_INFO_SERVICE_ID=info_service
SERVICE_CLIENT_INFO_SERVICE_SECRET=change-me-service-secret
SERVICE_CLIENT_INFO_SERVICE_SCOPE=user:read course:read calendar:read
SERVICE_CLIENT_INFO_SERVICE_AUDIENCE=info_service

# Gateway — 调用 /internal/verify 验证用户 Token
SERVICE_CLIENT_GATEWAY_ID=gateway
SERVICE_CLIENT_GATEWAY_SECRET=change-me-gateway-secret
SERVICE_CLIENT_GATEWAY_SCOPE=internal:verify
SERVICE_CLIENT_GATEWAY_AUDIENCE=gateway

# === 跨服务通信（本地开发用 localhost，Docker 内用 auth_service） ===
AUTH_SERVICE_URL=http://localhost:8001
AUTH_SERVICE_TIMEOUT=10

# === CORS（允许的前端来源，逗号分隔） ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,pdf,csv

# === 角色 ID（种子脚本按 code 顺序插入后确定）===
STUDENT_ROLE_ID=1
TEACHER_ROLE_ID=2

# === 种子数据 ===
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_USER_NO=STSS-ADMIN-001
SEED_ADMIN_FULL_NAME=系统管理员
