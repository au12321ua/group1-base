# ==========================================
# STSS-g1 环境变量模板
# 复制此文件为 .env 后即可本地运行
# cp .env.example .env
# ==========================================

# === 运行环境 ===
ENV=development

# === 日志 ===
LOG_LEVEL=DEBUG
LOG_OUTPUT=console
LOG_DIR=/var/log/stss/
LOG_ROTATION=daily
LOG_RETENTION=30

# === Auth Service 数据库（SQLite） ===
AUTH_DATABASE_URL=sqlite+aiosqlite:///./data/auth.db

# === Info Service 数据库（SQLite） ===
INFO_DATABASE_URL=sqlite+aiosqlite:///./data/info.db

# === 审计数据库（SQLite） ===
AUDIT_DATABASE_URL=sqlite+aiosqlite:///./data/audit.db

# === JWT 配置 ===
TOKEN_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=7
SERVICE_TOKEN_EXPIRE_HOURS=8

# === 密码加密 ===
BCRYPT_COST_FACTOR=12

# === 登录保护 ===
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=10

# === 跨服务通信（本地开发用 localhost，Docker 内用 auth_service） ===
AUTH_SERVICE_URL=http://localhost:8001

# === CORS（允许的前端来源，逗号分隔） ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,pdf,csv
